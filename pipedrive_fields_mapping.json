{
  "trigger": "zapier_webhook",

  "webhook_payload_expected": [
    "name",
    "email",
    "campaign",
    "event"
  ],

  "fields_mapping": [
    {
      "webhook_field": "name",
      "pipedrive_field": "person.name"
    },
    {
      "webhook_field": "email",
      "pipedrive_field": "person.email"
    },
    {
      "webhook_field": "campaign",
      "pipedrive_field": "note.content"
    },
    {
      "webhook_field": "event",
      "pipedrive_field": "note.content"
    }
  ],

  "automation_flow": [
    {
      "step": 1,
      "action": "Catch Hook (Zapier)"
    },
    {
      "step": 2,
      "action": "Find Person (Pipedrive)",
      "search_field": "email"
    },
    {
      "step": 3,
      "action": "Create Person (if not exists)"
    },
    {
      "step": 4,
      "action": "Update Person"
    },
    {
      "step": 5,
      "action": "Create Note",
      "template": "Campaign: {{campaign}} | Event: {{event}}"
    },
    {
      "step": 6,
      "action": "Zapier Paths"
    }
  ],

  "paths_logic": [
    {
      "condition": "event contains 'reply'",
      "action": "Create Activity",
      "activity_type": "meeting"
    },
    {
      "condition": "event contains 'open'",
      "action": "Create Activity",
      "activity_type": "email_opened"
    }
  ]
}
