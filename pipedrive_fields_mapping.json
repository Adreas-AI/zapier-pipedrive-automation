{
  "project": "zapier-webhook-to-pipedrive",
  "trigger": "Zapier Webhook (Catch Hook)",
  "webhook_payload_expected": ["name", "email", "campaign", "event"],

  "fields_mapping": [
    { "webhook_field": "name", "pipedrive_target": "person.name" },
    { "webhook_field": "email", "pipedrive_target": "person.email" },
    {
      "webhook_field": "campaign",
      "pipedrive_target": "note.content",
      "format_hint": "Include campaign in the note text"
    },
    {
      "webhook_field": "event",
      "pipedrive_target": "note.content",
      "format_hint": "Include event in the note text"
    }
  ],

  "flow_steps": [
    { "step": 1, "zapier_action": "Catch Hook", "result": "Receives JSON payload" },
    { "step": 2, "zapier_action": "Find Person (Pipedrive)", "key": "email" },
    { "step": 3, "zapier_action": "Create Person (if not found)", "inputs": ["name", "email"] },
    { "step": 4, "zapier_action": "Update Person (Pipedrive)", "inputs": ["name"] },
    {
      "step": 5,
      "zapier_action": "Create Note (Pipedrive)",
      "note_template": "Campaign: {{campaign}} | Event: {{event}}"
    },
    { "step": 6, "zapier_action": "Paths (conditional branching)", "based_on": "event" }
  ],

  "paths": [
    {
      "path": "A",
      "condition": "event contains 'reply'",
      "pipedrive_action": "Create Activity",
      "activity_type": "meeting",
      "activity_subject_template": "Meeting request (Campaign: {{campaign}})",
      "activity_note_template": "{{event}}"
    },
    {
      "path": "B",
      "condition": "event contains 'open'",
      "pipedrive_action": "Create Activity",
      "activity_type": "email_opened",
      "activity_subject_template": "Email opened (Campaign: {{campaign}})",
      "activity_note_template": "{{event}}"
    }
  ]
}
